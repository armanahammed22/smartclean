{
  "entities": {
    "Page": {
      "title": "Page",
      "description": "Represents a dynamic content page managed via the Pages Management System.",
      "type": "object",
      "properties": {
        "slug": {
          "type": "string",
          "description": "URL-friendly identifier for the page."
        },
        "title": {
          "type": "string",
          "description": "Human-readable title of the page."
        },
        "content": {
          "type": "string",
          "description": "HTML or rich text content of the page."
        },
        "isPublished": {
          "type": "boolean",
          "description": "Whether the page is visible to the public."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["slug", "title", "content", "isPublished", "updatedAt"]
    },
    "HeroBanner": {
      "title": "HeroBanner",
      "description": "Represents a slide in the homepage hero carousel.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "imageUrl": { "type": "string" },
        "isActive": { "type": "boolean" },
        "order": { "type": "number" },
        "buttonText": { "type": "string" },
        "buttonLink": { "type": "string" }
      }
    },
    "Lead": {
      "title": "Lead",
      "description": "A potential sales inquiry.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "source": { "type": "string" },
        "status": { "type": "string", "enum": ["New", "Contacted", "Qualified", "Lost"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "phone"]
  },
  "firestore": {
    "/hero_banners/{id}": {
      "schema": "HeroBanner",
      "description": "Dynamic slides for the homepage hero carousel."
    },
    "/pages_management/{slug}": {
      "schema": "Page",
      "description": "Stores content for dynamic static pages like About Us, careers, etc."
    },
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "Core user profile data."
    },
    "/roles_admins/{uid}": {
      "description": "Authorized admin users."
    },
    "/leads/{id}": {
      "schema": "Lead",
      "description": "Sales leads for tracking potential customers."
    }
  }
}