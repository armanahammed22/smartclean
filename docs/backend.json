{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An inventory item or equipment for sale.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "regularPrice": { "type": "number" },
        "stockQuantity": { "type": "number" },
        "categoryId": { "type": "string" },
        "brand": { "type": "string" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "isPopular": { "type": "boolean" },
        "salesCount": { "type": "number" },
        "shortDescription": { "type": "string" },
        "description": { "type": "string" },
        "galleryImages": { "type": "array", "items": { "type": "string" } },
        "features": { "type": "array", "items": { "type": "string" } },
        "specifications": { "type": "array", "items": { "type": "object" } },
        "variants": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["name", "price", "stockQuantity", "status"]
    },
    "Service": {
      "title": "Service",
      "description": "A professional cleaning or maintenance offering.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "basePrice": { "type": "number" },
        "duration": { "type": "string" },
        "description": { "type": "string" },
        "categoryId": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "isPopular": { "type": "boolean" },
        "imageUrl": { "type": "string" }
      },
      "required": ["title", "basePrice", "status"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A scheduled service appointment.",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "serviceId": { "type": "string" },
        "dateTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "totalPrice": { "type": "number" }
      },
      "required": ["customerId", "serviceId", "dateTime", "status"]
    },
    "SiteSettings": {
      "title": "SiteSettings",
      "description": "Global website configuration.",
      "type": "object",
      "properties": {
        "websiteName": { "type": "string" },
        "logoUrl": { "type": "string" },
        "contactEmail": { "type": "string" },
        "otpEnabled": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["password", "phone"]
  },
  "firestore": {
    "/products/{id}": { "schema": "Product", "description": "Product catalog." },
    "/services/{id}": { "schema": "Service", "description": "Services catalog." },
    "/bookings/{id}": { "schema": "Booking", "description": "Service appointments." },
    "/orders/{id}": { "description": "Product purchase records." },
    "/users/{uid}": { "description": "User profiles." },
    "/leads/{id}": { "description": "Sales leads." },
    "/employee_profiles/{id}": { "description": "Staff metadata." },
    "/hero_banners/{id}": { "description": "Homepage slides." },
    "/quick_links/{id}": { "description": "Icon navigation." },
    "/quick_actions/{id}": { "description": "Feature cards." },
    "/pages_management/{slug}": { "description": "CMS pages." },
    "/site_settings/{id}": { "description": "Global config." },
    "/payment_methods/{id}": { "description": "Payment gateways." },
    "/coupons/{id}": { "description": "Marketing coupons." },
    "/staff_availability/{uid}": { "description": "Technician status." },
    "/product_categories/{id}": { "description": "Product category hierarchy." },
    "/brands/{id}": { "description": "Authorized brand list." },
    "/sub_services/{id}": { "description": "Task add-ons for services." },
    "/service_areas/{id}": { "description": "Operational service regions." }
  }
}