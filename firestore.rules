
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function hasRole(role) {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_$(role)/$(request.auth.uid));
    }

    function isBootstrapAdmin() { 
      return isSignedIn() && request.auth.uid == "gcp03WmpjROVvRdpLNsghNU4zHa2"; 
    }
    
    function isAdmin() { return isBootstrapAdmin() || hasRole('admins'); }
    function isManager() { return isAdmin() || hasRole('managers'); }
    function isOrderManager() { return isManager() || hasRole('order_managers'); }
    function isStaff() { return isManager() || hasRole('employees'); }
    
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // BOOTSTRAP ADMIN: Full access override
    match /{document=**} {
      allow read, write: if isBootstrapAdmin();
    }

    // PUBLIC CATALOG
    match /products/{id} { allow read, list: if true; allow write: if isOrderManager(); }
    match /services/{id} { allow read, list: if true; allow write: if isManager(); }
    match /sub_services/{id} { allow read, list: if true; allow write: if isManager(); }
    match /product_categories/{id} { allow read, list: if true; allow write: if isOrderManager(); }
    match /brands/{id} { allow read, list: if true; allow write: if isOrderManager(); }
    match /service_areas/{id} { allow read, list: if true; allow write: if isManager(); }
    match /site_settings/{id} { allow read, list: if true; allow write: if isAdmin(); }
    match /payment_methods/{id} { allow read, list: if true; allow write: if isAdmin(); }

    // CRM DATA
    match /users/{uid} {
      allow create: if isOwner(uid);
      allow read, update: if isOwner(uid) || isStaff();
      allow delete: if isAdmin();
    }
    
    match /blocked_users/{id} {
      allow read: if true; // Allow signup check
      allow write: if isAdmin();
    }
    
    match /orders/{id} {
      allow create: if true;
      allow read: if isOrderManager() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow update, delete: if isOrderManager();
    }

    match /bookings/{id} {
      allow create: if true;
      allow read: if isManager() || (isSignedIn() && (resource.data.customerId == request.auth.uid || resource.data.employeeId == request.auth.uid));
      allow update: if isManager() || (isOwner(resource.data.employeeId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'lastLocation']));
      allow delete: if isManager();
    }

    match /leads/{id} {
      allow create: if true;
      allow read, write: if isManager();
    }

    match /support_tickets/{id} {
      allow create: if true;
      allow read: if isManager() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow update: if isManager();
      allow delete: if isAdmin();
    }

    match /referrals/{id} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || (isSignedIn() && resource.data.referrerId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /staff_availability/{uid} {
      allow read: if isStaff();
      allow write: if isOwner(uid) || isManager();
    }

    // ROLES MANAGEMENT
    match /roles_admins/{uid} { allow read: if isSignedIn(); allow write: if isBootstrapAdmin(); }
    match /roles_managers/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_employees/{uid} { allow read: if isSignedIn(); allow write: if isManager(); }
  }
}
