
/**
 * Firestore Security Rules
 *
 * Rules Version: 1.3
 * Fixed administrative listing permissions for bookings, orders, and leads.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isBootstrapAdmin() {
      return isSignedIn() && request.auth.uid == 'gcp03WmpjROVvRdpLNsghNU4zHa2';
    }

    function isAdmin() {
      return isBootstrapAdmin() || (
        isSignedIn() && exists(/databases/$(database)/documents/roles_admins/$(request.auth.uid))
      );
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // --- Public Content ---

    match /hero_banners/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /product_categories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /brands/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /sub_services/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /homepage_sections/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /quick_links/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /quick_actions/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonials/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /faq/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /site_settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /marketing_offers/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pages_management/{slug} {
      allow get: if resource == null || resource.data.isPublished == true || isAdmin();
      allow list: if true;
      allow write: if isAdmin();
    }

    // --- Auth Restricted Content ---

    match /users/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow write: if isOwner(uid) || isAdmin();
    }

    match /roles_admins/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /roles_employees/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /employee_profiles/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /staff_availability/{id} {
      allow read: if true;
      allow write: if isOwner(id) || isAdmin();
    }

    match /bookings/{id} {
      allow list: if isAdmin();
      allow get: if isAdmin() || (isSignedIn() && (resource.data.customerId == request.auth.uid || resource.data.employeeId == request.auth.uid));
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /orders/{id} {
      allow list: if isAdmin();
      allow get: if isAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /support_tickets/{id} {
      allow list: if isAdmin();
      allow get: if isAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /referrals/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.referrerId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /payment_methods/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /coupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- CRM & Leads ---
    match /leads/{id} {
      allow read, write: if isAdmin();
    }

    // --- Marketing Campaigns ---
    match /marketing_campaigns/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Product Attributes Templates ---
    match /reusable_features/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /reusable_specs/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /variant_types/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Staff Operations & Logistics ---
    match /staff_earnings/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.staffId == request.auth.uid);
      allow write: if isAdmin();
    }
    match /service_areas/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /couriers/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Additional Roles ---
    match /roles_managers/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_accounts/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_order_managers/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // --- Security Blacklist ---
    match /blocked_users/{id} {
      allow read, write: if isAdmin();
    }
  }
}
