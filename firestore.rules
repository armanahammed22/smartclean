rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isBootstrapAdmin() { 
      return isSignedIn() && request.auth.uid == "gcp03WmpjROVvRdpLNsghNU4zHa2"; 
    }
    
    function isAdmin() { 
      return isBootstrapAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/roles_admins/$(request.auth.uid))); 
    }
    
    function isEmployee() { 
      return isSignedIn() && exists(/databases/$(database)/documents/roles_employees/$(request.auth.uid)); 
    }
    
    function isStaff() { 
      return isAdmin() || isEmployee(); 
    }

    // PUBLIC CATALOG ACCESS
    // Explicitly allow anyone to read (get and list) catalog data
    match /products/{document=**} { allow read: if true; allow write: if isAdmin(); }
    match /services/{document=**} { allow read: if true; allow write: if isAdmin(); }
    match /product_categories/{document=**} { allow read: if true; allow write: if isAdmin(); }
    match /service_categories/{document=**} { allow read: if true; allow write: if isAdmin(); }
    match /brands/{document=**} { allow read: if true; allow write: if isAdmin(); }
    match /marketing_offers/{document=**} { allow read: if true; allow write: if isAdmin(); }
    match /marketing_campaigns/{document=**} { allow read: if true; allow write: if isAdmin(); }
    match /site_settings/{document=**} { allow read: if true; allow write: if isAdmin(); }
    match /service_areas/{document=**} { allow read: if true; allow write: if isAdmin(); }

    // OPERATIONAL DATA (Staff only)
    match /orders/{document=**} { allow read, write: if isStaff(); }
    match /bookings/{document=**} { allow read, write: if isStaff(); }
    match /leads/{document=**} { allow read, write: if isStaff(); }
    match /customers/{document=**} { allow read, write: if isStaff(); }
    match /employee_profiles/{document=**} { allow read: if isStaff(); allow write: if isAdmin(); }
    
    // ROLE DEFINITIONS
    match /roles_admins/{uid} { allow read: if isSignedIn(); allow write: if isBootstrapAdmin(); }
    match /roles_employees/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // Global Catch-all for Bootstrap Admin
    match /{document=**} {
      allow read, write: if isBootstrapAdmin();
    }
  }
}