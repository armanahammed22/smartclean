rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements a robust Role-Based Access Control (RBAC) system.
     * It specifically authorizes the bootstrap administrator UID (gcp03WmpjROVvRdpLNsghNU4zHa2)
     * to ensure immediate access to CRM management tools.
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Authorize via roles_admins collection OR the hardcoded bootstrap UID
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admins/$(request.auth.uid)) ||
        request.auth.uid == "gcp03WmpjROVvRdpLNsghNU4zHa2"
      );
    }

    function isEmployee() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_employees/$(request.auth.uid));
    }

    function isStaff() {
      return isAdmin() || isEmployee();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- CRM Collections ---

    match /leads/{leadId} {
      allow get, list, create, update, delete: if isStaff();
    }

    match /bookings/{bookingId} {
      allow get, list, create, update, delete: if isStaff();
    }

    // --- Staff and Profiles ---

    match /admin_profiles/{adminId} {
      allow get, list: if isAdmin() || isOwner(adminId);
      allow create, update, delete: if isAdmin() || (isOwner(adminId) && request.resource.data.id == adminId);
    }

    match /employee_profiles/{employeeId} {
      allow get, list: if isStaff();
      allow create, update, delete: if isAdmin() || (isOwner(employeeId) && request.resource.data.id == employeeId);
    }

    match /roles_admins/{uid} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /roles_employees/{uid} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Public Shop / Catalog ---

    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isStaff();
    }

    match /customers/{customerId} {
      allow get, list: if isStaff() || isOwner(customerId);
      allow create: if isStaff() || (isOwner(customerId) && request.resource.data.id == customerId);
      allow update, delete: if isStaff() || (isOwner(customerId));
    }

    match /orders/{orderId} {
      allow get, list: if isStaff() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow create: if isStaff() || (isSignedIn() && request.resource.data.customerId == request.auth.uid);
      allow update, delete: if isStaff();

      match /order_items/{itemId} {
        allow read, write: if isStaff() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      }
    }
  }
}