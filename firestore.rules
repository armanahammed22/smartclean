
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic auth helper functions
    function isSignedIn() { return request.auth != null; }
    function isBootstrapAdmin() { return isSignedIn() && request.auth.uid == "gcp03WmpjROVvRdpLNsghNU4zHa2"; }
    function isAdmin() { return isBootstrapAdmin() || exists(/databases/$(database)/documents/roles_admins/$(request.auth.uid)); }
    function isEmployee() { return exists(/databases/$(database)/documents/roles_employees/$(request.auth.uid)); }
    function isStaff() { return isAdmin() || isEmployee(); }

    // Admin catch-all: Bootstrap admin can do anything
    match /{document=**} {
      allow read, write: if isBootstrapAdmin();
    }

    // Publicly accessible content (Catalog, Marketing, Settings)
    match /products/{id} { allow read: if true; allow write: if isAdmin(); }
    match /services/{id} { allow read: if true; allow write: if isAdmin(); }
    match /product_categories/{id} { allow read: if true; allow write: if isAdmin(); }
    match /service_categories/{id} { allow read: if true; allow write: if isAdmin(); }
    match /brands/{id} { allow read: if true; allow write: if isAdmin(); }
    match /marketing_offers/{id} { allow read: if true; allow write: if isAdmin(); }
    match /marketing_campaigns/{id} { allow read: if true; allow write: if isAdmin(); }
    match /site_settings/{id} { allow read: if true; allow write: if isAdmin(); }
    match /service_areas/{id} { allow read: if true; allow write: if isAdmin(); }

    // Restricted Operational Data (Staff/Admin only)
    match /orders/{id} { allow read, write: if isStaff(); }
    match /bookings/{id} { allow read, write: if isStaff(); }
    match /leads/{id} { allow read, write: if isStaff(); }
    match /customers/{id} { allow read, write: if isStaff(); }
    match /employee_profiles/{id} { allow read: if isStaff(); allow write: if isAdmin(); }
    
    // Role Markers
    match /roles_admins/{uid} { allow read: if isSignedIn(); allow write: if isBootstrapAdmin(); }
    match /roles_employees/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
  }
}
