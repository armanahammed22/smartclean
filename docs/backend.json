
{
  "entities": {
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Fixed-price cleaning supplies and equipment.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "stockQuantity": { "type": "number" }
      },
      "required": ["id", "name", "price"]
    },
    "Service": {
      "title": "Service",
      "type": "object",
      "description": "Variable-price cleaning services offered by the company.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "basePrice": { "type": "number" },
        "duration": { "type": "string", "description": "e.g., 2 hours" },
        "description": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["id", "title", "basePrice"]
    },
    "Lead": {
      "title": "Lead",
      "type": "object",
      "description": "Potential customer captured from marketing channels.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "status": { "type": "string", "enum": ["New", "Contacted", "Qualified", "Lost"] },
        "source": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "companyId": { "type": "string" }
      }
    },
    "Booking": {
      "title": "Booking",
      "type": "object",
      "description": "A scheduled cleaning service appointment.",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceTitle": { "type": "string" },
        "employeeId": { "type": "string" },
        "employeeName": { "type": "string" },
        "dateTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Pending", "Assigned", "In Progress", "Completed", "Cancelled"] },
        "totalPrice": { "type": "number" },
        "companyId": { "type": "string" }
      }
    },
    "EmployeeProfile": {
      "title": "EmployeeProfile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string" },
        "completedJobs": { "type": "number" },
        "companyId": { "type": "string" }
      }
    },
    "Subscription": {
      "title": "Subscription",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "plan": { "type": "string", "enum": ["Basic", "Pro", "Enterprise"] },
        "status": { "type": "string" },
        "expiryDate": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "#/entities/Lead",
      "description": "Sales leads tracking."
    },
    "/bookings/{bookingId}": {
      "schema": "#/entities/Booking",
      "description": "Service appointments."
    },
    "/services/{serviceId}": {
      "schema": "#/entities/Service",
      "description": "Available cleaning services."
    },
    "/employee_profiles/{employeeId}": {
      "schema": "#/entities/EmployeeProfile",
      "description": "Employee directory."
    },
    "/subscriptions/{companyId}": {
      "schema": "#/entities/Subscription",
      "description": "Company subscription data."
    }
  }
}
