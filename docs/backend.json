
{
  "entities": {
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Fixed-price cleaning supplies and equipment.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "subCategory": { "type": "string" },
        "imageUrl": { "type": "string" },
        "stockQuantity": { "type": "number" },
        "sku": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "name", "price"]
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "description": "Product sales order.",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Processing", "Shipped", "Delivered", "Cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["Unpaid", "Paid", "Refunded"] },
        "paymentMethod": { "type": "string" },
        "courier": { "type": "string" },
        "trackingId": { "type": "string" },
        "items": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Service": {
      "title": "Service",
      "type": "object",
      "description": "Variable-price cleaning services.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "basePrice": { "type": "number" },
        "duration": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] }
      }
    },
    "Customer": {
      "title": "Customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "segment": { "type": "string" },
        "totalSpent": { "type": "number" }
      }
    },
    "ServiceArea": {
      "title": "ServiceArea",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/leads/{leadId}": { "schema": "#/entities/Lead", "description": "Sales leads." },
    "/bookings/{bookingId}": { "schema": "#/entities/Booking", "description": "Service appointments." },
    "/orders/{orderId}": { "schema": "#/entities/Order", "description": "Product orders." },
    "/services/{serviceId}": { "schema": "#/entities/Service", "description": "Services catalog." },
    "/products/{productId}": { "schema": "#/entities/Product", "description": "Inventory items." },
    "/customers/{customerId}": { "schema": "#/entities/Customer", "description": "Customer profiles." },
    "/service_areas/{areaId}": { "schema": "#/entities/ServiceArea", "description": "Supported regions." },
    "/employee_profiles/{employeeId}": { "schema": "#/entities/EmployeeProfile", "description": "Staff directory." }
  }
}
