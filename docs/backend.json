
{
  "entities": {
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Fixed-price cleaning supplies and equipment.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "categoryId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "stockQuantity": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] }
      },
      "required": ["id", "name", "price", "categoryId"]
    },
    "Service": {
      "title": "Service",
      "type": "object",
      "description": "Cleaning and maintenance service offerings.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "basePrice": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "imageUrl": { "type": "string" }
      },
      "required": ["id", "title", "basePrice", "status"]
    },
    "EmployeeProfile": {
      "title": "EmployeeProfile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string" },
        "skills": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of Service IDs this technician is qualified for."
        },
        "rating": { "type": "number" },
        "jobsCompleted": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "On Leave", "Terminated", "Banned"] }
      }
    },
    "BlockedUser": {
      "title": "BlockedUser",
      "type": "object",
      "description": "Blacklisted credentials to prevent re-registration.",
      "properties": {
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "blockedAt": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "CustomerProfile": {
      "title": "CustomerProfile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "referralCode": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "staff", "admin"], "default": "customer" },
        "status": { "type": "string", "enum": ["active", "restricted", "disabled", "banned"], "default": "active" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/products/{productId}": { "schema": "#/entities/Product", "description": "Inventory items." },
    "/services/{serviceId}": { "schema": "#/entities/Service", "description": "Service offerings." },
    "/employee_profiles/{id}": { "schema": "#/entities/EmployeeProfile", "description": "Technician skill and rating data." },
    "/bookings/{id}": { "schema": "#/entities/Booking", "description": "Service appointments." },
    "/orders/{id}": { "schema": "#/entities/Order", "description": "Sales records." },
    "/customer_profiles/{uid}": { "schema": "#/entities/CustomerProfile", "description": "User profiles." },
    "/blocked_users/{id}": { "schema": "#/entities/BlockedUser", "description": "Blacklisted credentials." },
    "/roles_admins/{uid}": { "schema": "object", "description": "Super Admin access." },
    "/roles_managers/{uid}": { "schema": "object", "description": "Ops Manager access." },
    "/roles_employees/{uid}": { "schema": "object", "description": "Field staff access." }
  }
}
