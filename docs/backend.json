
{
  "entities": {
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Fixed-price cleaning supplies and equipment.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "regularPrice": { "type": "number" },
        "categoryId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "stockQuantity": { "type": "number" },
        "brand": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "variants": { "type": "array", "items": { "type": "object" } },
        "features": { "type": "array", "items": { "type": "string" } },
        "specifications": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["id", "name", "price", "categoryId"]
    },
    "Brand": {
      "title": "Brand",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "VariantType": {
      "title": "VariantType",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } }
      }
    },
    "ReusableFeature": {
      "title": "ReusableFeature",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "ReusableSpec": {
      "title": "ReusableSpec",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "key": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{uid}": { "schema": "#/entities/User", "description": "Unified user accounts." },
    "/products/{productId}": { "schema": "#/entities/Product", "description": "Inventory items." },
    "/product_categories/{id}": { "schema": "object", "description": "Product groupings." },
    "/brands/{id}": { "schema": "#/entities/Brand", "description": "Product brands." },
    "/variant_types/{id}": { "schema": "#/entities/VariantType", "description": "Reusable variant types." },
    "/reusable_features/{id}": { "schema": "#/entities/ReusableFeature", "description": "Standard features." },
    "/reusable_specs/{id}": { "schema": "#/entities/ReusableSpec", "description": "Technical specification keys." },
    "/services/{serviceId}": { "schema": "#/entities/Service", "description": "Main services." },
    "/site_settings/{id}": { "schema": "object", "description": "Global config & UI." },
    "/heroBannerSettings/{id}": { "schema": "object", "description": "Homepage hero content." },
    "/bookings/{id}": { "schema": "#/entities/Booking", "description": "Service appointments." },
    "/orders/{id}": { "schema": "object", "description": "Product sales." }
  }
}
