
{
  "entities": {
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Fixed-price cleaning supplies and equipment.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "categoryId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "stockQuantity": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] }
      },
      "required": ["id", "name", "price", "categoryId"]
    },
    "Service": {
      "title": "Service",
      "type": "object",
      "description": "Cleaning and maintenance service offerings.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "basePrice": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "imageUrl": { "type": "string" }
      },
      "required": ["id", "title", "basePrice", "status"]
    },
    "User": {
      "title": "User",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "staff", "admin"], "default": "customer" },
        "status": { "type": "string", "enum": ["active", "banned", "disabled"], "default": "active" }
      }
    },
    "Booking": {
      "title": "Booking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceTitle": { "type": "string" },
        "employeeId": { "type": "string" },
        "employeeName": { "type": "string" },
        "status": { "type": "string", "enum": ["New", "Assigned", "On The Way", "Service Started", "Completed", "Cancelled"] },
        "totalPrice": { "type": "number" },
        "dateTime": { "type": "string", "format": "date-time" }
      }
    },
    "EmployeeProfile": {
      "title": "EmployeeProfile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "rating": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "On Leave", "Terminated"] }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{uid}": { "schema": "#/entities/User", "description": "Unified user accounts." },
    "/products/{productId}": { "schema": "#/entities/Product", "description": "Inventory items." },
    "/services/{serviceId}": { "schema": "#/entities/Service", "description": "Main services." },
    "/sub_services/{id}": { "schema": "object", "description": "Task add-ons." },
    "/bookings/{id}": { "schema": "#/entities/Booking", "description": "Service appointments." },
    "/orders/{id}": { "schema": "object", "description": "Product sales." },
    "/leads/{id}": { "schema": "object", "description": "Sales inquiries." },
    "/support_tickets/{id}": { "schema": "object", "description": "Customer issues." },
    "/referrals/{id}": { "schema": "object", "description": "Affiliate logs." },
    "/staff_availability/{uid}": { "schema": "object", "description": "Real-time tech status." },
    "/employee_profiles/{uid}": { "schema": "#/entities/EmployeeProfile", "description": "Staff metadata." },
    "/site_settings/{id}": { "schema": "object", "description": "Global config & UI." },
    "/payment_methods/{id}": { "schema": "object", "description": "Gateway configs." },
    "/couriers/{id}": { "schema": "object", "description": "Logistics partners." },
    "/quick_links/{id}": { "schema": "object", "description": "UI Grid links." },
    "/quick_actions/{id}": { "schema": "object", "description": "UI Feature cards." },
    "/blocked_users/{id}": { "schema": "object", "description": "Blacklisted credentials." },
    "/roles_admins/{uid}": { "schema": "object", "description": "Admin privileges." },
    "/roles_managers/{uid}": { "schema": "object", "description": "Manager privileges." },
    "/roles_employees/{uid}": { "schema": "object", "description": "Staff privileges." }
  }
}
