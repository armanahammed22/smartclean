
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An inventory item or equipment for sale.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "regularPrice": { "type": "number" },
        "stockQuantity": { "type": "number" },
        "categoryId": { "type": "string" },
        "brand": { "type": "string" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "isPopular": { "type": "boolean" },
        "salesCount": { "type": "number" }
      },
      "required": ["name", "price", "stockQuantity", "status"]
    },
    "Service": {
      "title": "Service",
      "description": "A professional cleaning or maintenance offering.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "basePrice": { "type": "number" },
        "duration": { "type": "string" },
        "description": { "type": "string" },
        "categoryId": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "isPopular": { "type": "boolean" }
      },
      "required": ["title", "basePrice", "status"]
    },
    "Order": {
      "title": "Order",
      "description": "A purchase record for physical products.",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "items": { "type": "array" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["New", "Processing", "Shipped", "Delivered", "Cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Booking": {
      "title": "Booking",
      "description": "A scheduled service appointment.",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "serviceId": { "type": "string" },
        "dateTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["New", "Assigned", "On The Way", "Service Started", "Completed", "Cancelled"] },
        "employeeId": { "type": "string" }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Metadata for registered customers.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "Page": {
      "title": "Page",
      "description": "A CMS page managed through the Pages Management module.",
      "type": "object",
      "properties": {
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "isPublished": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "phone"]
  },
  "firestore": {
    "/products/{id}": { "schema": "Product", "description": "Product catalog." },
    "/services/{id}": { "schema": "Service", "description": "Professional services catalog." },
    "/orders/{id}": { "schema": "Order", "description": "Product purchase records." },
    "/bookings/{id}": { "schema": "Booking", "description": "Service appointment records." },
    "/users/{uid}": { "schema": "UserProfile", "description": "User account data." },
    "/pages_management/{id}": { "schema": "Page", "description": "Informational CMS pages." },
    "/leads/{id}": { "description": "Sales inquiries." },
    "/hero_banners/{id}": { "description": "Dynamic homepage slides." },
    "/site_settings/{id}": { "description": "Global website configuration." }
  }
}
