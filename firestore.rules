rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isBootstrapAdmin() { 
      return isSignedIn() && request.auth.uid == "gcp03WmpjROVvRdpLNsghNU4zHa2"; 
    }
    
    function isAdmin() { 
      return isBootstrapAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/roles_admins/$(request.auth.uid))); 
    }
    
    function isEmployee() { 
      return isSignedIn() && exists(/databases/$(database)/documents/roles_employees/$(request.auth.uid)); 
    }
    
    function isStaff() { 
      return isAdmin() || isEmployee(); 
    }

    // PUBLIC CATALOG ACCESS: Explicitly allow unauthenticated read (get/list)
    // We use a broader match to ensure top-level collection listing is permitted
    match /products/{allPaths=**} { allow read: if true; allow write: if isAdmin(); }
    match /services/{allPaths=**} { allow read: if true; allow write: if isAdmin(); }
    match /sub_services/{allPaths=**} { allow read: if true; allow write: if isAdmin(); }
    match /product_categories/{allPaths=**} { allow read: if true; allow write: if isAdmin(); }
    match /service_categories/{allPaths=**} { allow read: if true; allow write: if isAdmin(); }
    match /brands/{allPaths=**} { allow read: if true; allow write: if isAdmin(); }
    match /marketing_offers/{allPaths=**} { allow read: if true; allow write: if isAdmin(); }
    match /marketing_campaigns/{allPaths=**} { allow read: if true; allow write: if isAdmin(); }
    match /site_settings/{allPaths=**} { allow read: if true; allow write: if isAdmin(); }
    match /service_areas/{allPaths=**} { allow read: if true; allow write: if isAdmin(); }

    // OPERATIONAL DATA
    match /orders/{allPaths=**} { allow read, write: if isStaff(); }
    match /bookings/{allPaths=**} { allow read, write: if isStaff(); }
    match /leads/{allPaths=**} { allow read, write: if true; } // Allow public lead submission
    match /customers/{allPaths=**} { allow read, write: if isStaff(); }
    match /employee_profiles/{allPaths=**} { allow read: if isStaff(); allow write: if isAdmin(); }
    
    // ROLE DEFINITIONS
    match /roles_admins/{uid} { allow read: if isSignedIn(); allow write: if isBootstrapAdmin(); }
    match /roles_employees/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // Global Catch-all for Bootstrap Admin (Safety)
    match /{document=**} {
      allow read, write: if isBootstrapAdmin();
    }
  }
}