
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An inventory item or equipment for sale.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "regularPrice": { "type": "number" },
        "stockQuantity": { "type": "number" },
        "categoryId": { "type": "string" },
        "brand": { "type": "string" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "isPopular": { "type": "boolean" },
        "salesCount": { "type": "number" },
        "shortDescription": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name", "price", "stockQuantity", "status"]
    },
    "Category": {
      "title": "Category",
      "description": "Main level marketplace category.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "imageUrl": { "type": "string" },
        "order": { "type": "number" }
      }
    },
    "Subcategory": {
      "title": "Subcategory",
      "description": "Second level category.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "categoryId": { "type": "string" },
        "order": { "type": "number" }
      }
    },
    "ChildCategory": {
      "title": "ChildCategory",
      "description": "Third level category.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "subcategoryId": { "type": "string" },
        "order": { "type": "number" }
      }
    },
    "Courier": {
      "title": "Courier",
      "description": "A logistics provider with dynamic API configuration.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "status": { "type": "string" },
        "description": { "type": "string" },
        "apiEndpoint": { "type": "string" },
        "apiKey": { "type": "string" },
        "apiSecret": { "type": "string" },
        "trackingUrl": { "type": "string" },
        "fieldMapping": { "type": "string", "description": "JSON string mapping internal fields to API fields." },
        "color": { "type": "string" }
      },
      "required": ["name", "apiEndpoint", "status"]
    },
    "Order": {
      "title": "Order",
      "description": "A product purchase record with risk analytics.",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "address": { "type": "string" },
        "items": { "type": "array" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string" },
        "courierId": { "type": "string" },
        "trackingId": { "type": "string" },
        "riskLevel": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "isSuspicious": { "type": "boolean" },
        "ipAddress": { "type": "string" },
        "deviceInfo": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Service": {
      "title": "Service",
      "description": "A professional cleaning or maintenance offering.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "basePrice": { "type": "number" },
        "duration": { "type": "string" },
        "description": { "type": "string" },
        "categoryId": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "imageUrl": { "type": "string" }
      },
      "required": ["title", "basePrice", "status"]
    },
    "Campaign": {
      "title": "Campaign",
      "description": "A marketing mega sale event.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "bannerImage": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" },
        "priority": { "type": "number" },
        "description": { "type": "string" },
        "themeColor": { "type": "string" }
      },
      "required": ["title", "slug", "startDate", "endDate", "isActive"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A service appointment record.",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "serviceTitle": { "type": "string" },
        "dateTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "totalPrice": { "type": "number" },
        "employeeId": { "type": "string" }
      }
    },
    "Offer": {
      "title": "Offer",
      "description": "A circular navbar banner offer.",
      "type": "object",
      "properties": {
        "image": { "type": "string" },
        "link": { "type": "string" },
        "isActive": { "type": "boolean" },
        "order": { "type": "number" }
      },
      "required": ["image", "link", "isActive"]
    },
    "TrackingLog": {
      "title": "TrackingLog",
      "description": "A log of marketing events sent to external platforms.",
      "type": "object",
      "properties": {
        "eventName": { "type": "string" },
        "eventId": { "type": "string" },
        "platform": { "type": "string", "enum": ["Facebook", "Google"] },
        "method": { "type": "string", "enum": ["Browser", "Server"] },
        "status": { "type": "string" },
        "payload": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "phone"]
  },
  "firestore": {
    "/products/{id}": { "schema": "Product", "description": "Product catalog." },
    "/categories/{id}": { "schema": "Category", "description": "Main level categories." },
    "/subcategories/{id}": { "schema": "Subcategory", "description": "Sub categories." },
    "/childcategories/{id}": { "schema": "ChildCategory", "description": "Child categories." },
    "/services/{id}": { "schema": "Service", "description": "Services catalog." },
    "/orders/{id}": { "schema": "Order", "description": "Transactional records." },
    "/bookings/{id}": { "schema": "Booking", "description": "Service appointments." },
    "/couriers/{id}": { "schema": "Courier", "description": "Logistics providers." },
    "/campaigns/{id}": { "schema": "Campaign", "description": "Mega sale events." },
    "/campaigns/{id}/products/{pId}": { "schema": "object", "description": "Products participating in a campaign." },
    "/offers/{id}": { "schema": "Offer", "description": "Navbar offer banners." },
    "/tracking_logs/{id}": { "schema": "TrackingLog", "description": "Logs for Facebook/Google events." },
    "/site_settings/{id}": { "schema": "object", "description": "Global settings for marketing and SEO." }
  }
}
