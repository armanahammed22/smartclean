
{
  "entities": {
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Fixed-price cleaning supplies and equipment with variant support.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "categoryId": { "type": "string" },
        "subCategoryId": { "type": "string" },
        "brandId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "stockQuantity": { "type": "number" },
        "sku": { "type": "string" },
        "description": { "type": "string" },
        "variants": { "type": "array" }
      },
      "required": ["id", "name", "price", "categoryId"]
    },
    "ProductCategory": {
      "title": "ProductCategory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "icon": { "type": "string" },
        "parentId": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] }
      }
    },
    "ServiceCategory": {
      "title": "ServiceCategory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "icon": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] }
      }
    },
    "Brand": {
      "title": "Brand",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] }
      }
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "description": "Product sales order.",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Processing", "Shipped", "Delivered", "Cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["Unpaid", "Paid", "Refunded"] },
        "paymentMethod": { "type": "string" },
        "items": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Service": {
      "title": "Service",
      "type": "object",
      "description": "Variable-price cleaning services.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "categoryId": { "type": "string" },
        "basePrice": { "type": "number" },
        "duration": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/product_categories/{catId}": { "schema": "#/entities/ProductCategory", "description": "Product hierarchies." },
    "/service_categories/{catId}": { "schema": "#/entities/ServiceCategory", "description": "Service categories." },
    "/brands/{brandId}": { "schema": "#/entities/Brand", "description": "Product brands." },
    "/orders/{orderId}": { "schema": "#/entities/Order", "description": "Product orders." },
    "/services/{serviceId}": { "schema": "#/entities/Service", "description": "Services catalog." },
    "/products/{productId}": { "schema": "#/entities/Product", "description": "Inventory items." },
    "/leads/{leadId}": { "schema": "#/entities/Lead", "description": "Sales leads." },
    "/bookings/{bookingId}": { "schema": "#/entities/Booking", "description": "Service appointments." },
    "/customers/{customerId}": { "schema": "#/entities/Customer", "description": "Customer profiles." }
  }
}
