
{
  "entities": {
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Fixed-price cleaning supplies and equipment.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "categoryId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "stockQuantity": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] }
      },
      "required": ["id", "name", "price", "categoryId"]
    },
    "Service": {
      "title": "Service",
      "type": "object",
      "description": "Cleaning and maintenance service offerings.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "basePrice": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "imageUrl": { "type": "string" }
      },
      "required": ["id", "title", "basePrice", "status"]
    },
    "EmployeeProfile": {
      "title": "EmployeeProfile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string" },
        "skills": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of Service IDs this technician is qualified for."
        },
        "rating": { "type": "number" },
        "jobsCompleted": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "On Leave", "Terminated"] }
      }
    },
    "StaffAvailability": {
      "title": "StaffAvailability",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "isOnline": { "type": "boolean" },
        "status": { "type": "string", "enum": ["Available", "Busy", "Offline"] },
        "lastLocation": { "type": "object" },
        "activeCity": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    },
    "StaffEarnings": {
      "title": "StaffEarnings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "staffId": { "type": "string" },
        "bookingId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["commission", "bonus", "base"] },
        "createdAt": { "type": "string" }
      }
    },
    "CustomerProfile": {
      "title": "CustomerProfile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "referralCode": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/products/{productId}": { "schema": "#/entities/Product", "description": "Inventory items." },
    "/services/{serviceId}": { "schema": "#/entities/Service", "description": "Service offerings." },
    "/employee_profiles/{id}": { "schema": "#/entities/EmployeeProfile", "description": "Technician skill and rating data." },
    "/bookings/{id}": { "schema": "#/entities/Booking", "description": "Service appointments." },
    "/orders/{id}": { "schema": "#/entities/Order", "description": "Sales records." },
    "/customer_profiles/{uid}": { "schema": "#/entities/CustomerProfile", "description": "User profiles." },
    "/staff_availability/{uid}": { "schema": "#/entities/StaffAvailability", "description": "Technician real-time status." },
    "/staff_earnings/{id}": { "schema": "#/entities/StaffEarnings", "description": "Technician payout records." },
    "/roles_admins/{uid}": { "schema": "object", "description": "Super Admin access." },
    "/roles_managers/{uid}": { "schema": "object", "description": "Ops Manager access." },
    "/roles_accounts/{uid}": { "schema": "object", "description": "Finance access." },
    "/roles_order_managers/{uid}": { "schema": "object", "description": "E-commerce access." },
    "/roles_employees/{uid}": { "schema": "object", "description": "Field staff access." }
  }
}
