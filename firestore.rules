
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core Auth Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    // Comprehensive Admin Check
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'Q8QpZP1GzzWf2f2K6WTe476PcD92' ||
        request.auth.token.email == 'smartclean422@gmail.com' ||
        exists(/databases/$(database)/documents/roles_admins/$(request.auth.uid))
      );
    }

    // Team Leader Check for live location
    function isTeamLeader(bookingId) {
      return isSignedIn() && get(/databases/$(database)/documents/bookings/$(bookingId)).data.teamLeaderId == request.auth.uid;
    }

    // 🛡️ GLOBAL ADMIN OVERRIDE
    match /{allPaths=**} {
      allow read, write: if isSignedIn() && (
        request.auth.uid == 'Q8QpZP1GzzWf2f2K6WTe476PcD92' ||
        request.auth.token.email == 'smartclean422@gmail.com'
      );
    }

    // Tracking Rules
    match /live_locations/{bookingId} {
      allow read: if true; 
      allow write: if isTeamLeader(bookingId);
    }

    match /site_settings/{id} { allow read: if true; allow write: if isAdmin(); }

    // Public Collections & Marketing Data
    match /products/{id} { allow read: if true; allow write: if isAdmin(); }
    match /services/{id} { allow read: if true; allow write: if isAdmin(); }
    match /sub_services/{id} { allow read: if true; allow write: if isAdmin(); }
    match /smart_pricing_rules/{id} { allow read: if true; allow write: if isAdmin(); }
    match /coupons/{id} { allow read: if true; allow write: if isAdmin(); }
    match /campaigns/{id} { 
      allow read: if true; allow write: if isAdmin(); 
      match /products/{pId} { allow read: if true; allow write: if isAdmin(); }
    }
    
    // UI & Layout
    match /homepage_sections/{id} { allow read: if true; allow write: if isAdmin(); }
    match /hero_banners/{id} { allow read: if true; allow write: if isAdmin(); }
    match /top_nav_categories/{id} { allow read: if true; allow write: if isAdmin(); }
    match /quick_links/{id} { allow read: if true; allow write: if isAdmin(); }
    match /quick_actions/{id} { allow read: if true; allow write: if isAdmin(); }
    match /delivery_options/{id} { allow read: if true; allow write: if isAdmin(); }
    match /payment_methods/{id} { allow read: if true; allow write: if isAdmin(); }
    match /marketing_offers/{id} { allow read: if true; allow write: if isAdmin(); }
    match /pages_management/{id} { allow read: if true; allow write: if isAdmin(); }
    match /offers/{id} { allow read: if true; allow write: if isAdmin(); }
    match /brands/{id} { allow read: if true; allow write: if isAdmin(); }

    match /bookings/{id} { 
      allow create: if true; 
      allow read: if isSignedIn(); 
      allow update: if isAdmin() || (isSignedIn() && resource.data.teamLeaderId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Custom Requests Rules
    match /custom_requests/{id} {
      allow create: if true;
      allow read: if (isSignedIn() && (resource.data.customerId == request.auth.uid || isAdmin())) || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /employee_profiles/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /staff_availability/{id} { allow read: if true; allow write: if isSignedIn() && request.auth.uid == id; }
    match /staff_earnings/{id} { allow read: if isSignedIn() && (resource.data.staffId == request.auth.uid || isAdmin()); allow write: if isAdmin(); }
    
    match /invoices/{id} { allow read: if true; allow write: if isAdmin(); }
    match /invoiceRequests/{id} { allow create: if isSignedIn(); allow read, write: if isAdmin(); }
    
    match /roles_admins/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_employees/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /users/{uid} { allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin()); }
  }
}
