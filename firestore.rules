
/**
 * Firestore Security Rules
 * Version 2.2: Standardized public access for catalogs and strictly enforced admin oversight.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isBootstrapAdmin() {
      return isSignedIn() && request.auth.uid == 'gcp03WmpjROVvRdpLNsghNU4zHa2';
    }

    function isAdmin() {
      return isBootstrapAdmin() || (
        isSignedIn() && (
          exists(/databases/$(database)/documents/roles_admins/$(request.auth.uid)) ||
          exists(/databases/$(database)/documents/roles_managers/$(request.auth.uid)) ||
          exists(/databases/$(database)/documents/roles_order_managers/$(request.auth.uid)) ||
          exists(/databases/$(database)/documents/roles_accounts/$(request.auth.uid))
        )
      );
    }

    function isStaff() {
      return isSignedIn() && (
        isAdmin() || exists(/databases/$(database)/documents/roles_employees/$(request.auth.uid))
      );
    }

    // --- Public Catalogs (Read-Only for all, Write for Admins) ---

    match /products/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /product_categories/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /brands/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /services/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /sub_services/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /service_categories/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /service_areas/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /hero_banners/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /quick_links/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /quick_actions/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /homepage_sections/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /marketing_offers/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /pages_management/{slug} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /site_settings/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // --- User & Role Data ---

    match /users/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow write: if isOwner(uid) || isAdmin();
    }

    match /employee_profiles/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /staff_availability/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid) || isAdmin();
    }

    // --- Transactions ---

    match /bookings/{id} {
      allow list: if isAdmin() || isStaff();
      allow get: if isAdmin() || isStaff() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow create: if true; 
      allow update: if isAdmin() || (isStaff() && resource.data.employeeId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /orders/{id} {
      allow list: if isAdmin();
      allow get: if isAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow create: if true; 
      allow update, delete: if isAdmin();
    }

    match /support_tickets/{id} {
      allow list: if isAdmin();
      allow get: if isAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow create: if true; 
      allow update, delete: if isAdmin();
    }

    match /leads/{id} {
      allow get, list, write: if isAdmin();
    }

    match /blocked_users/{id} { allow read, write: if isAdmin(); }
    match /roles_admins/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_managers/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_order_managers/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_accounts/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_employees/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    
    match /staff_earnings/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.staffId == request.auth.uid);
      allow write: if isAdmin();
    }
    
    match /coupons/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /payment_methods/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /referrals/{id} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.referrerId == request.auth.uid);
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 100);
      allow write: if isAdmin();
    }

    match /reusable_features/{id} { allow read: if true; allow write: if isAdmin(); }
    match /reusable_specs/{id} { allow read: if true; allow write: if isAdmin(); }
    match /variant_types/{id} { allow read: if true; allow write: if isAdmin(); }
  }
}
