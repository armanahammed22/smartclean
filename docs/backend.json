
{
  "entities": {
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Fixed-price cleaning supplies and equipment.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "regularPrice": { "type": "number" },
        "categoryId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "galleryImages": { "type": "array", "items": { "type": "string" } },
        "stockQuantity": { "type": "number" },
        "brand": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "variants": { "type": "array", "items": { "type": "object" } },
        "features": { "type": "array", "items": { "type": "string" } },
        "specifications": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["id", "name", "price", "categoryId"]
    },
    "HeroBanner": {
      "title": "HeroBanner",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "imageUrl": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "isActive": { "type": "boolean" },
        "order": { "type": "number" },
        "isTextEnabled": { "type": "boolean" },
        "textAlignment": { "type": "string", "enum": ["left", "center", "right"] },
        "textPosition": { "type": "string", "enum": ["top", "center", "bottom"] },
        "titleColor": { "type": "string" },
        "titleSize": { "type": "string" },
        "overlayColor": { "type": "string" },
        "overlayOpacity": { "type": "number" },
        "isButtonEnabled": { "type": "boolean" },
        "buttonText": { "type": "string" },
        "buttonLink": { "type": "string" },
        "buttonColor": { "type": "string" },
        "buttonSize": { "type": "string" },
        "buttonShape": { "type": "string" },
        "buttonPosition": { "type": "string" }
      }
    },
    "Testimonial": {
      "title": "Testimonial",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "content": { "type": "string" },
        "rating": { "type": "number" },
        "avatarUrl": { "type": "string" }
      }
    },
    "FAQ": {
      "title": "FAQ",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "question": { "type": "string" },
        "answer": { "type": "string" },
        "order": { "type": "number" },
        "isActive": { "type": "boolean" }
      }
    },
    "HomepageSection": {
      "title": "HomepageSection",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" },
        "order": { "type": "number" },
        "isActive": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["password", "phone"]
  },
  "firestore": {
    "/users/{uid}": { "schema": "#/entities/User", "description": "Unified user accounts." },
    "/roles_admins/{uid}": { "schema": "object", "description": "Admin authorization mapping." },
    "/roles_managers/{uid}": { "schema": "object", "description": "Manager authorization mapping." },
    "/roles_employees/{uid}": { "schema": "object", "description": "Staff authorization mapping." },
    "/products/{id}": { "schema": "#/entities/Product", "description": "Inventory items." },
    "/product_categories/{id}": { "schema": "object", "description": "Product groupings." },
    "/brands/{id}": { "schema": "object", "description": "Product brands." },
    "/variant_types/{id}": { "schema": "object", "description": "Reusable variant types." },
    "/reusable_features/{id}": { "schema": "object", "description": "Standard features." },
    "/reusable_specs/{id}": { "schema": "object", "description": "Technical specification keys." },
    "/services/{id}": { "schema": "object", "description": "Main services catalog." },
    "/sub_services/{id}": { "schema": "object", "description": "Service add-ons." },
    "/hero_banners/{id}": { "schema": "#/entities/HeroBanner", "description": "Home page hero slides." },
    "/quick_actions/{id}": { "schema": "object", "description": "Home screen shortcuts." },
    "/quick_links/{id}": { "schema": "object", "description": "Home screen navigation grid." },
    "/homepage_sections/{id}": { "schema": "#/entities/HomepageSection", "description": "Dynamic homepage layout blocks." },
    "/offers/{id}": { "schema": "object", "description": "Promotional deals." },
    "/testimonials/{id}": { "schema": "#/entities/Testimonial", "description": "Customer social proof." },
    "/faq/{id}": { "schema": "#/entities/FAQ", "description": "Frequently asked questions." },
    "/footer_settings/{id}": { "schema": "object", "description": "Global footer configuration." },
    "/header_settings/{id}": { "schema": "object", "description": "Global header configuration." },
    "/contact_info/{id}": { "schema": "object", "description": "Business contact details." },
    "/social_links/{id}": { "schema": "object", "description": "Social media profiles." },
    "/site_settings/global": { "schema": "object", "description": "Global config & UI." },
    "/site_settings/support_hub": { "schema": "object", "description": "Floating support agent config." },
    "/bookings/{id}": { "schema": "object", "description": "Service appointments." },
    "/orders/{id}": { "schema": "#/entities/Order", "description": "Product sales." },
    "/support_tickets/{id}": { "schema": "object", "description": "Customer support requests." },
    "/service_areas/{id}": { "schema": "object", "description": "Supported coverage zones." }
  }
}
