
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isBootstrapAdmin() { return isSignedIn() && request.auth.uid == "gcp03WmpjROVvRdpLNsghNU4zHa2"; }
    function isAdmin() { return isBootstrapAdmin() || exists(/databases/$(database)/documents/roles_admins/$(request.auth.uid)); }
    function isEmployee() { return exists(/databases/$(database)/documents/roles_employees/$(request.auth.uid)); }
    function isStaff() { return isAdmin() || isEmployee(); }

    match /{document=**} {
      allow read, write: if isBootstrapAdmin();
    }

    match /product_categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /service_categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /orders/{orderId} {
      allow read, write: if isStaff();
    }
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /bookings/{bookingId} {
      allow read, write: if isStaff();
    }
    match /leads/{leadId} {
      allow read, write: if isStaff();
    }
  }
}
