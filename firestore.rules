
/**
 * Firestore Security Rules
 * Optimized for Smart Clean SaaS - Reliable public access and hardened admin controls.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Global Helpers ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isBootstrapAdmin() {
      return isSignedIn() && request.auth.uid == 'gcp03WmpjROVvRdpLNsghNU4zHa2';
    }

    function isAdmin() {
      return isBootstrapAdmin() || (
        isSignedIn() && (
          exists(/databases/$(database)/documents/roles_admins/$(request.auth.uid)) ||
          exists(/databases/$(database)/documents/roles_managers/$(request.auth.uid))
        )
      );
    }

    function isStaff() {
      return isSignedIn() && (
        isBootstrapAdmin() ||
        exists(/databases/$(database)/documents/roles_admins/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/roles_managers/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/roles_employees/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- 1. Public Marketplace Access (Everyone can Read) ---
    
    match /products/{id} { allow read: if true; allow write: if isAdmin(); }
    match /services/{id} { allow read: if true; allow write: if isAdmin(); }
    match /campaigns/{id} { allow read: if true; allow write: if isAdmin(); }
    match /campaigns/{id}/products/{pId} { allow read: if true; allow write: if isAdmin(); }
    match /product_categories/{id} { allow read: if true; allow write: if isAdmin(); }
    match /service_categories/{id} { allow read: if true; allow write: if isAdmin(); }
    match /top_nav_categories/{id} { allow read: if true; allow write: if isAdmin(); }
    match /sub_services/{id} { allow read: if true; allow write: if isAdmin(); }
    match /brands/{id} { allow read: if true; allow write: if isAdmin(); }
    match /hero_banners/{id} { allow read: if true; allow write: if isAdmin(); }
    match /site_settings/{id} { allow read: if true; allow write: if isAdmin(); }
    match /pages_management/{id} { allow read: if true; allow write: if isAdmin(); }
    match /quick_links/{id} { allow read: if true; allow write: if isAdmin(); }
    match /quick_actions/{id} { allow read: if true; allow write: if isAdmin(); }
    match /service_areas/{id} { allow read: if true; allow write: if isAdmin(); }
    match /marketing_offers/{id} { allow read: if true; allow write: if isAdmin(); }
    match /homepage_sections/{id} { allow read: if true; allow write: if isAdmin(); }
    match /payment_methods/{id} { allow read: if true; allow write: if isAdmin(); }
    match /coupons/{id} { allow read: if true; allow write: if isAdmin(); }
    match /reusable_features/{id} { allow read: if true; allow write: if isAdmin(); }
    match /reusable_specs/{id} { allow read: if true; allow write: if isAdmin(); }
    match /variant_types/{id} { allow read: if true; allow write: if isAdmin(); }
    match /delivery_options/{id} { allow read: if true; allow write: if isAdmin(); }

    // --- 2. Identity & Role Access ---

    match /users/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow write: if isOwner(uid) || isAdmin();
    }

    match /roles_admins/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_managers/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_employees/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_accounts/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_order_managers/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // --- 3. Transactional Data (Protected) ---

    match /bookings/{id} {
      allow create: if true; 
      allow list: if isAdmin() || isStaff() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow get: if isAdmin() || isStaff() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow update: if isAdmin() || (isStaff() && resource.data.employeeId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /orders/{id} {
      allow create: if true; 
      allow list: if isAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /support_tickets/{id} {
      allow create: if true;
      allow list: if isAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /leads/{id} {
      allow read, write: if isAdmin();
    }

    match /referrals/{id} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.referrerId == request.auth.uid);
      allow list: if isAdmin() || (isSignedIn() && resource.data.referrerId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /staff_availability/{uid} {
      allow read: if true;
      allow write: if isAdmin() || isOwner(uid);
    }

    match /staff_earnings/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.staffId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /employee_profiles/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /blocked_users/{id} {
      allow read, write: if isAdmin();
    }
    
    match /couriers/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
