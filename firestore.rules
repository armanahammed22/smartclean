
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Deployment Sync: 2026-03-23T01:30:00Z
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == '6YTKdslETkVXcftvhSY5x9sjOgT2' ||
        request.auth.token.email == 'smartclean422@gmail.com' ||
        exists(/databases/$(database)/documents/roles_admins/$(request.auth.uid))
      );
    }

    // Public Collections
    match /products/{id} { allow read: if true; allow write: if isAdmin(); }
    match /categories/{id} { allow read: if true; allow write: if isAdmin(); }
    match /subcategories/{id} { allow read: if true; allow write: if isAdmin(); }
    match /childcategories/{id} { allow read: if true; allow write: if isAdmin(); }
    match /landing_pages/{id} { allow read: if true; allow write: if isAdmin(); }
    match /campaigns/{id} { allow read: if true; allow write: if isAdmin(); }
    match /campaigns/{cid}/products/{pid} { allow read: if true; allow write: if isAdmin(); }
    match /product_qna/{id} { allow read: if true; allow create: if isSignedIn(); allow update, delete: if isAdmin(); }
    
    match /services/{id} { 
      allow read: if true; 
      allow write: if isAdmin(); 
      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /hero_banners/{id} { allow read: if true; allow write: if isAdmin(); }
    match /top_nav_categories/{id} { allow read: if true; allow write: if isAdmin(); }
    match /site_settings/{id} { allow read: if true; allow write: if isAdmin(); }
    match /offers/{id} { allow read: if true; allow write: if isAdmin(); }
    match /marketing_offers/{id} { allow read: if true; allow write: if isAdmin(); }
    match /pages_management/{id} { allow read: if true; allow write: if isAdmin(); }
    match /variant_types/{id} { allow read: if true; allow write: if isAdmin(); }
    match /reusable_features/{id} { allow read: if true; allow write: if isAdmin(); }
    match /reusable_specs/{id} { allow read: if true; allow write: if isAdmin(); }
    match /quick_links/{id} { allow read: if true; allow write: if isAdmin(); }
    match /quick_actions/{id} { allow read: if true; allow write: if isAdmin(); }
    match /homepage_sections/{id} { allow read: if true; allow write: if isAdmin(); }
    match /delivery_options/{id} { allow read: if true; allow write: if isAdmin(); }
    match /payment_methods/{id} { allow read: if true; allow write: if isAdmin(); }
    match /coupons/{id} { allow read: if true; allow write: if isAdmin(); }
    match /service_areas/{id} { allow read: if true; allow write: if isAdmin(); }
    match /employee_profiles/{id} { allow read: if true; allow write: if isAdmin(); }

    // Protected Collections
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }

    match /vendor_profiles/{id} {
      allow read, write: if isAdmin();
    }

    match /blocked_users/{id} {
      allow read, write: if isAdmin();
    }

    match /orders/{id} {
      allow create: if true;
      allow read: if isAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /bookings/{id} {
      allow create: if true;
      allow read: if isAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /tracking_logs/{id} { 
      allow read: if isAdmin(); 
      allow write: if true;
    }
    
    match /error_logs/{id} { allow create: if true; allow read, write: if isAdmin(); }
    
    match /roles_admins/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_managers/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_accounts/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_order_managers/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_employees/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    
    match /staff_availability/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /leads/{id} { allow read, write: if isAdmin(); }
    match /brands/{id} { allow read: if true; allow write: if isAdmin(); }
    
    match /support_tickets/{id} { 
      allow create: if isSignedIn(); 
      allow read, update: if isAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
    }
    
    match /staff_earnings/{id} { allow read, write: if isAdmin(); }
    match /referrals/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    
    match /couriers/{id} {
      allow read, write: if isAdmin();
    }
  }
}
