
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An inventory item or equipment for sale.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "regularPrice": { "type": "number" },
        "stockQuantity": { "type": "number" },
        "categoryId": { "type": "string" },
        "brand": { "type": "string" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "isPopular": { "type": "boolean" },
        "salesCount": { "type": "number" },
        "shortDescription": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name", "price", "stockQuantity", "status"]
    },
    "Courier": {
      "title": "Courier",
      "description": "A logistics provider with dynamic API configuration.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "status": { "type": "string" },
        "description": { "type": "string" },
        "apiEndpoint": { "type": "string" },
        "apiKey": { "type": "string" },
        "apiSecret": { "type": "string" },
        "trackingUrl": { "type": "string" },
        "fieldMapping": { "type": "string", "description": "JSON string mapping internal fields to API fields." },
        "color": { "type": "string" }
      },
      "required": ["name", "apiEndpoint", "status"]
    },
    "Service": {
      "title": "Service",
      "description": "A professional cleaning or maintenance offering.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "basePrice": { "type": "number" },
        "duration": { "type": "string" },
        "description": { "type": "string" },
        "categoryId": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "imageUrl": { "type": "string" }
      },
      "required": ["title", "basePrice", "status"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A scheduled service appointment.",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "serviceId": { "type": "string" },
        "dateTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "totalPrice": { "type": "number" }
      }
    },
    "PaymentMethod": {
      "title": "Payment Method",
      "description": "Configuration for a payment gateway.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["cod", "cash", "mobile", "card"] },
        "accountNumber": { "type": "string" },
        "instructions": { "type": "string" },
        "isEnabled": { "type": "boolean" },
        "isDefaultForProducts": { "type": "boolean" },
        "isDefaultForServices": { "type": "boolean" }
      }
    },
    "TopNavCategory": {
      "title": "Top Nav Category",
      "description": "A link in the top horizontal navigation bar.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "link": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["name", "order"]
    }
  },
  "auth": {
    "providers": ["password", "phone"]
  },
  "firestore": {
    "/products/{id}": { "schema": "Product", "description": "Product catalog." },
    "/services/{id}": { "schema": "Service", "description": "Services catalog." },
    "/bookings/{id}": { "schema": "Booking", "description": "Service appointments." },
    "/orders/{id}": { "description": "Product purchase records." },
    "/users/{uid}": { "description": "User profiles." },
    "/leads/{id}": { "description": "Sales leads." },
    "/employee_profiles/{id}": { "description": "Staff metadata." },
    "/site_settings/{id}": { "description": "Global config." },
    "/top_nav_categories/{id}": { "schema": "TopNavCategory", "description": "Managed horizontal navigation links." },
    "/staff_availability/{uid}": { "description": "Technician status." },
    "/product_categories/{id}": { "description": "Product hierarchy." },
    "/service_categories/{id}": { "description": "Service hierarchy." },
    "/brands/{id}": { "description": "Authorized brand list." },
    "/sub_services/{id}": { "description": "Task add-ons." },
    "/service_areas/{id}": { "description": "Service regions." },
    "/marketing_offers/{id}": { "description": "Promotional banners." },
    "/reusable_features/{id}": { "description": "Feature templates." },
    "/reusable_specs/{id}": { "description": "Spec templates." },
    "/variant_types/{id}": { "description": "Variant templates." },
    "/coupons/{id}": { "description": "Discount codes." },
    "/payment_methods/{id}": { "schema": "PaymentMethod", "description": "Payment gateways." },
    "/support_tickets/{id}": { "description": "Help requests." },
    "/referrals/{id}": { "description": "Affiliate logs." },
    "/hero_banners/{id}": { "description": "Homepage slider content." },
    "/homepage_sections/{id}": { "description": "Visibility toggles for main UI." },
    "/pages_management/{id}": { "description": "CMS for dynamic pages." },
    "/couriers/{id}": { "schema": "Courier", "description": "Dynamic logistics providers." }
  }
}
