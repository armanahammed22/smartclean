{
  "entities": {
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Fixed-price cleaning supplies and equipment.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "categoryId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "stockQuantity": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] }
      },
      "required": ["id", "name", "price", "categoryId"]
    },
    "Service": {
      "title": "Service",
      "type": "object",
      "description": "Cleaning and maintenance service offerings.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "basePrice": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "imageUrl": { "type": "string" }
      },
      "required": ["id", "title", "basePrice", "status"]
    },
    "SubService": {
      "title": "SubService",
      "type": "object",
      "description": "Specific tasks within a main service.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "duration": { "type": "string" },
        "mainServiceId": { "type": "string" }
      },
      "required": ["id", "name", "price", "mainServiceId"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/products/{productId}": { "schema": "#/entities/Product", "description": "Inventory items." },
    "/services/{serviceId}": { "schema": "#/entities/Service", "description": "Service offerings." },
    "/sub_services/{id}": { "schema": "#/entities/SubService", "description": "Add-on services." },
    "/bookings/{id}": { "schema": "#/entities/Booking", "description": "Service appointments." },
    "/product_categories/{catId}": { "schema": "#/entities/ProductCategory", "description": "Product hierarchy." }
  }
}