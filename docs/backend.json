
{
  "entities": {
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Fixed-price cleaning supplies and equipment with variant support.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "categoryId": { "type": "string" },
        "subCategoryId": { "type": "string" },
        "brandId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "stockQuantity": { "type": "number" },
        "sku": { "type": "string" },
        "description": { "type": "string" },
        "variants": { "type": "array" }
      },
      "required": ["id", "name", "price", "categoryId"]
    },
    "ProductCategory": {
      "title": "ProductCategory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "icon": { "type": "string" },
        "parentId": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] }
      }
    },
    "ServiceCategory": {
      "title": "ServiceCategory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "icon": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] }
      }
    },
    "SiteSettings": {
      "title": "SiteSettings",
      "type": "object",
      "properties": {
        "websiteName": { "type": "string" },
        "logoUrl": { "type": "string" },
        "faviconUrl": { "type": "string" },
        "contactEmail": { "type": "string" },
        "contactPhone": { "type": "string" },
        "address": { "type": "string" },
        "socialLinks": { "type": "object" },
        "currency": { "type": "string" },
        "defaultLanguage": { "type": "string" },
        "seoTitle": { "type": "string" },
        "seoDescription": { "type": "string" },
        "footerContent": { "type": "string" }
      }
    },
    "HomepageCustomization": {
      "title": "HomepageCustomization",
      "type": "object",
      "properties": {
        "hero": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "subtitle": { "type": "string" },
            "imageUrl": { "type": "string" },
            "ctaText": { "type": "string" },
            "enabled": { "type": "boolean" }
          }
        },
        "sections": {
          "type": "object",
          "properties": {
            "popularProducts": { "type": "boolean" },
            "recentProducts": { "type": "boolean" },
            "popularServices": { "type": "boolean" },
            "campaigns": { "type": "boolean" }
          }
        },
        "featuredProductIds": { "type": "array", "items": { "type": "string" } },
        "featuredServiceIds": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/product_categories/{catId}": { "schema": "#/entities/ProductCategory", "description": "Product hierarchies." },
    "/service_categories/{catId}": { "schema": "#/entities/ServiceCategory", "description": "Service categories." },
    "/brands/{brandId}": { "schema": "#/entities/Brand", "description": "Product brands." },
    "/orders/{orderId}": { "schema": "#/entities/Order", "description": "Product orders." },
    "/services/{serviceId}": { "schema": "#/entities/Service", "description": "Services catalog." },
    "/products/{productId}": { "schema": "#/entities/Product", "description": "Inventory items." },
    "/site_settings/global": { "schema": "#/entities/SiteSettings", "description": "Global website configuration." },
    "/site_settings/homepage": { "schema": "#/entities/HomepageCustomization", "description": "Homepage layout control." }
  }
}
