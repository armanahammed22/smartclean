
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic Auth Helpers
    function isSignedIn() { return request.auth != null; }
    function isBootstrapAdmin() { return isSignedIn() && request.auth.uid == "gcp03WmpjROVvRdpLNsghNU4zHa2"; }
    function hasRole(role) { return isSignedIn() && exists(/databases/$(database)/documents/roles_$(role)/$(request.auth.uid)); }
    
    // Role Helpers
    function isAdmin() { return isBootstrapAdmin() || hasRole('admins'); }
    function isManager() { return isAdmin() || hasRole('managers'); }
    function isOrderManager() { return isManager() || hasRole('order_managers'); }
    function isStaff() { return hasRole('employees'); }

    // Public Content (Anyone can view)
    match /hero_banners/{id} { allow read: if true; allow write: if isAdmin(); }
    match /quick_links/{id} { allow read: if true; allow write: if isAdmin(); }
    match /quick_actions/{id} { allow read: if true; allow write: if isAdmin(); }
    match /homepage_sections/{id} { allow read: if true; allow write: if isAdmin(); }
    match /offers/{id} { allow read: if true; allow write: if isAdmin(); }
    match /testimonials/{id} { allow read: if true; allow write: if isAdmin(); }
    match /faq/{id} { allow read: if true; allow write: if isAdmin(); }
    match /header_settings/{id} { allow read: if true; allow write: if isAdmin(); }
    match /footer_settings/{id} { allow read: if true; allow write: if isAdmin(); }
    match /contact_info/{id} { allow read: if true; allow write: if isAdmin(); }
    match /social_links/{id} { allow read: if true; allow write: if isAdmin(); }
    match /site_settings/{id} { allow read: if true; allow write: if isAdmin(); }
    match /products/{id} { allow read: if true; allow write: if isOrderManager(); }
    match /product_categories/{id} { allow read: if true; allow write: if isOrderManager(); }
    match /brands/{id} { allow read: if true; allow write: if isOrderManager(); }
    match /services/{id} { allow read: if true; allow write: if isAdmin(); }
    match /sub_services/{id} { allow read: if true; allow write: if isAdmin(); }
    match /service_areas/{id} { allow read: if true; allow write: if isAdmin(); }

    // User & Profile Data
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }

    // Transactions
    match /orders/{id} { 
      allow create: if true; 
      allow read: if isSignedIn() && (resource.data.customerId == request.auth.uid || isOrderManager());
      allow write: if isOrderManager(); 
    }
    match /bookings/{id} { 
      allow create: if true; 
      allow read: if isSignedIn() && (resource.data.customerId == request.auth.uid || isAdmin() || isStaff());
      allow write: if isAdmin() || isStaff(); 
    }

    // Role Assignments
    match /roles_admins/{uid} { allow read: if isSignedIn(); allow write: if isBootstrapAdmin(); }
    match /roles_managers/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_order_managers/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_employees/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // Global Fallback
    match /{document=**} {
      allow read, write: if isBootstrapAdmin();
    }
  }
}
