
{
  "entities": {
    "LandingPage": {
      "title": "LandingPage",
      "description": "Configuration for a dynamic product or service landing page.",
      "type": "object",
      "properties": {
        "slug": { "type": "string" },
        "type": { "type": "string", "enum": ["product", "service"] },
        "title": { "type": "string" },
        "active": { "type": "boolean" },
        "bannerImage": { "type": "string" },
        "productIds": { "type": "array" },
        "packages": { "type": "array" },
        "addOns": { "type": "array" }
      }
    },
    "OrderLandingProduct": {
      "title": "OrderLandingProduct",
      "description": "Order record from a product landing page.",
      "type": "object",
      "properties": {
        "pageId": { "type": "string" },
        "customerName": { "type": "string" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string" }
      }
    },
    "OrderLandingService": {
      "title": "OrderLandingService",
      "description": "Order record from a service landing page.",
      "type": "object",
      "properties": {
        "pageId": { "type": "string" },
        "customerName": { "type": "string" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/landing_pages/{id}": { "schema": "LandingPage", "description": "Dynamic landing pages." },
    "/orders_products/{id}": { "schema": "OrderLandingProduct", "description": "Product sales orders." },
    "/orders_services/{id}": { "schema": "OrderLandingService", "description": "Service booking orders." }
  }
}
