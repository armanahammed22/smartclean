
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isBootstrapAdmin() { return isSignedIn() && request.auth.uid == "gcp03WmpjROVvRdpLNsghNU4zHa2"; }
    function hasRole(role) { return isSignedIn() && exists(/databases/$(database)/documents/roles_$(role)/$(request.auth.uid)); }
    function isAdmin() { return isBootstrapAdmin() || hasRole('admins'); }
    function isOrderManager() { return isAdmin() || hasRole('managers') || hasRole('order_managers'); }

    match /{document=**} {
      allow read, write: if isBootstrapAdmin();
    }

    match /hero_banners/{id} { allow read: if true; allow write: if isAdmin(); }
    match /products/{id} { allow read: if true; allow write: if isOrderManager(); }
    match /product_categories/{id} { allow read: if true; allow write: if isOrderManager(); }
    match /brands/{id} { allow read: if true; allow write: if isOrderManager(); }
    match /variant_types/{id} { allow read: if true; allow write: if isOrderManager(); }
    match /reusable_features/{id} { allow read: if true; allow write: if isOrderManager(); }
    match /reusable_specs/{id} { allow read: if true; allow write: if isOrderManager(); }
    
    match /services/{id} { allow read: if true; allow write: if isAdmin(); }
    match /sub_services/{id} { allow read: if true; allow write: if isAdmin(); }
    match /site_settings/{id} { allow read: if true; allow write: if isAdmin(); }
    match /payment_methods/{id} { allow read: if true; allow write: if isAdmin(); }
    match /coupons/{id} { allow read: if true; allow write: if isAdmin(); }
    
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }

    match /employee_profiles/{id} { allow read: if true; allow write: if isAdmin(); }
    match /staff_availability/{id} { allow read: if true; allow write: if isSignedIn(); }

    match /orders/{id} { allow create: if true; allow read: if isSignedIn(); allow write: if isOrderManager(); }
    match /bookings/{id} { allow create: if true; allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /leads/{id} { allow create: if true; allow read: if isAdmin(); }
  }
}
