{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An inventory item or equipment for sale.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "regularPrice": { "type": "number" },
        "stockQuantity": { "type": "number" },
        "categoryId": { "type": "string" },
        "brand": { "type": "string" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "isPopular": { "type": "boolean" },
        "salesCount": { "type": "number" },
        "shortDescription": { "type": "string" },
        "description": { "type": "string" },
        "galleryImages": { "type": "array", "items": { "type": "string" } },
        "features": { "type": "array", "items": { "type": "string" } },
        "specifications": { "type": "array", "items": { "type": "object" } },
        "variants": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["name", "price", "stockQuantity", "status"]
    },
    "ProductCategory": {
      "title": "ProductCategory",
      "description": "Hierarchy for grouping products.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "parentId": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "Brand": {
      "title": "Brand",
      "description": "Manufacturer or brand registry.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "Service": {
      "title": "Service",
      "description": "A professional cleaning or maintenance offering.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "basePrice": { "type": "number" },
        "duration": { "type": "string" },
        "description": { "type": "string" },
        "categoryId": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "isPopular": { "type": "boolean" },
        "imageUrl": { "type": "string" },
        "galleryImages": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "basePrice", "status"]
    },
    "SubService": {
      "title": "SubService",
      "description": "A specialized task add-on for a main service.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "duration": { "type": "string" },
        "mainServiceId": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] }
      }
    },
    "Order": {
      "title": "Order",
      "description": "A purchase record for physical products.",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerEmail": { "type": "string" },
        "items": { "type": "array" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["New", "Processing", "Shipped", "Delivered", "Cancelled"] },
        "paymentMethod": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Booking": {
      "title": "Booking",
      "description": "A scheduled service appointment.",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerEmail": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceTitle": { "type": "string" },
        "dateTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["New", "Assigned", "On The Way", "Service Started", "Completed", "Cancelled"] },
        "employeeId": { "type": "string" },
        "employeeName": { "type": "string" },
        "address": { "type": "string" },
        "totalPrice": { "type": "number" }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Metadata for registered customers.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string" },
        "status": { "type": "string" },
        "address": { "type": "string" },
        "referralCode": { "type": "string" },
        "totalEarnings": { "type": "number" }
      }
    },
    "EmployeeProfile": {
      "title": "EmployeeProfile",
      "description": "Information about cleaning staff.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "rating": { "type": "number" },
        "jobsCompleted": { "type": "number" },
        "status": { "type": "string" }
      }
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "description": "A customer inquiry or support request.",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["Open", "Replied", "Closed"] },
        "adminReply": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "SiteSettings": {
      "title": "SiteSettings",
      "description": "Global configuration for the website.",
      "type": "object",
      "properties": {
        "websiteName": { "type": "string" },
        "logoUrl": { "type": "string" },
        "contactEmail": { "type": "string" },
        "contactPhone": { "type": "string" },
        "otpEnabled": { "type": "boolean" },
        "socialLinks": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": ["password", "phone"]
  },
  "firestore": {
    "/products/{id}": { "schema": "Product", "description": "Product catalog." },
    "/product_categories/{id}": { "schema": "ProductCategory", "description": "Inventory taxonomy." },
    "/brands/{id}": { "schema": "Brand", "description": "Product manufacturers." },
    "/services/{id}": { "schema": "Service", "description": "Professional services catalog." },
    "/sub_services/{id}": { "schema": "SubService", "description": "Task add-ons." },
    "/service_categories/{id}": { "description": "Service taxonomy." },
    "/service_areas/{id}": { "description": "Coverage regions." },
    "/orders/{id}": { "schema": "Order", "description": "Product purchase records." },
    "/bookings/{id}": { "schema": "Booking", "description": "Service appointment records." },
    "/users/{uid}": { "schema": "UserProfile", "description": "User account data." },
    "/employee_profiles/{id}": { "schema": "EmployeeProfile", "description": "Staff metadata." },
    "/support_tickets/{id}": { "schema": "SupportTicket", "description": "Customer support inquiries." },
    "/pages_management/{slug}": { "description": "Dynamic CMS content." },
    "/leads/{id}": { "description": "Sales inquiries." },
    "/site_settings/{id}": { "schema": "SiteSettings", "description": "Global configuration." },
    "/hero_banners/{id}": { "description": "Hero slider data." },
    "/quick_links/{id}": { "description": "Icon navigation." },
    "/quick_actions/{id}": { "description": "Homepage feature cards." },
    "/homepage_sections/{id}": { "description": "Layout control blocks." },
    "/marketing_offers/{id}": { "description": "Banners and promotions." },
    "/coupons/{id}": { "description": "Discount codes." },
    "/referrals/{id}": { "description": "Affiliate tracking." },
    "/payment_methods/{id}": { "description": "Configured gateways." },
    "/staff_availability/{uid}": { "description": "Technician real-time status." },
    "/staff_earnings/{id}": { "description": "Commission and base pay records." },
    "/reusable_features/{id}": { "description": "Product highlight templates." },
    "/reusable_specs/{id}": { "description": "Technical data templates." },
    "/variant_types/{id}": { "description": "Product variation templates." }
  }
}