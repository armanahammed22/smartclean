
{
  "entities": {
    "Page": {
      "title": "Page",
      "description": "Represents a dynamic content page managed via the Pages Management System.",
      "type": "object",
      "properties": {
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "isPublished": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["slug", "title", "content", "isPublished", "updatedAt"]
    },
    "Lead": {
      "title": "Lead",
      "description": "A potential sales inquiry.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "source": { "type": "string" },
        "status": { "type": "string", "enum": ["New", "Contacted", "Qualified", "Lost"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Product": {
      "title": "Product",
      "description": "Inventory item for sale.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "regularPrice": { "type": "number" },
        "stockQuantity": { "type": "number" },
        "categoryId": { "type": "string" },
        "brand": { "type": "string" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] }
      }
    },
    "Booking": {
      "title": "Booking",
      "description": "A scheduled service appointment.",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "serviceTitle": { "type": "string" },
        "dateTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["New", "Assigned", "On The Way", "Service Started", "Completed", "Cancelled"] }
      }
    },
    "Order": {
      "title": "Order",
      "description": "A product purchase record.",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["New", "Processing", "Shipped", "Delivered", "Cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "EmployeeProfile": {
      "title": "EmployeeProfile",
      "description": "Information about a staff member.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "status": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "auth": {
    "providers": ["password", "phone"]
  },
  "firestore": {
    "/hero_banners/{id}": { "schema": "HeroBanner", "description": "Dynamic homepage banners." },
    "/pages_management/{slug}": { "schema": "Page", "description": "CMS pages." },
    "/users/{uid}": { "description": "User profiles." },
    "/leads/{id}": { "schema": "Lead", "description": "Sales leads." },
    "/orders/{id}": { "schema": "Order", "description": "Product orders." },
    "/bookings/{id}": { "schema": "Booking", "description": "Service bookings." },
    "/employee_profiles/{id}": { "schema": "EmployeeProfile", "description": "Staff profiles." },
    "/service_areas/{id}": { "description": "Regions where services are offered." }
  }
}
