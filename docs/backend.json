
{
  "entities": {
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Fixed-price cleaning supplies and equipment.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "categoryId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "stockQuantity": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] }
      },
      "required": ["id", "name", "price", "categoryId"]
    },
    "Service": {
      "title": "Service",
      "type": "object",
      "description": "Cleaning and maintenance service offerings.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "basePrice": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "imageUrl": { "type": "string" }
      },
      "required": ["id", "title", "basePrice", "status"]
    },
    "CustomerProfile": {
      "title": "CustomerProfile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "totalEarnings": { "type": "number" }
      }
    },
    "Coupon": {
      "title": "Coupon",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discountType": { "type": "string", "enum": ["flat", "percent"] },
        "value": { "type": "number" },
        "expiryDate": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["Open", "Replied", "Closed"] },
        "createdAt": { "type": "string" }
      }
    },
    "QuickLink": {
      "title": "QuickLink",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "iconName": { "type": "string" },
        "link": { "type": "string" },
        "order": { "type": "number" }
      }
    },
    "QuickAction": {
      "title": "QuickAction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "iconName": { "type": "string" },
        "link": { "type": "string" },
        "bgGradient": { "type": "string" }
      }
    },
    "PaymentMethod": {
      "title": "PaymentMethod",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "accountNumber": { "type": "string" },
        "instructions": { "type": "string" },
        "isEnabled": { "type": "boolean" },
        "isDefaultForProducts": { "type": "boolean" },
        "isDefaultForServices": { "type": "boolean" },
        "apiKey": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/products/{productId}": { "schema": "#/entities/Product", "description": "Inventory items." },
    "/services/{serviceId}": { "schema": "#/entities/Service", "description": "Service offerings." },
    "/sub_services/{id}": { "schema": "#/entities/SubService", "description": "Add-on services." },
    "/bookings/{id}": { "schema": "#/entities/Booking", "description": "Service appointments." },
    "/orders/{id}": { "schema": "#/entities/Order", "description": "Sales records." },
    "/customer_profiles/{uid}": { "schema": "#/entities/CustomerProfile", "description": "User profiles." },
    "/coupons/{id}": { "schema": "#/entities/Coupon", "description": "Discount codes." },
    "/support_tickets/{id}": { "schema": "#/entities/SupportTicket", "description": "Customer support requests." },
    "/referrals/{id}": { "schema": "#/entities/Referral", "description": "Affiliate tracking." },
    "/quick_links/{id}": { "schema": "#/entities/QuickLink", "description": "Home icon grid links." },
    "/quick_actions/{id}": { "schema": "#/entities/QuickAction", "description": "Home prominent action cards." },
    "/payment_methods/{id}": { "schema": "#/entities/PaymentMethod", "description": "Payment gateway configuration." }
  }
}
