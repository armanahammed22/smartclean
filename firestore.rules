
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isBootstrapAdmin() { 
      return isSignedIn() && request.auth.uid == "gcp03WmpjROVvRdpLNsghNU4zHa2"; 
    }
    
    function isAdmin() { 
      return isBootstrapAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/roles_admins/$(request.auth.uid))); 
    }
    
    function isEmployee() { 
      return isSignedIn() && exists(/databases/$(database)/documents/roles_employees/$(request.auth.uid)); 
    }
    
    function isStaff() { 
      return isAdmin() || isEmployee(); 
    }

    // Publicly accessible content (Catalog, Marketing, Settings)
    // We explicitly allow 'read' (get and list) for unauthenticated users.
    
    match /products/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /products/{docId=**} { allow read: if true; }
    
    match /services/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /services/{docId=**} { allow read: if true; }
    
    match /product_categories/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /product_categories/{docId=**} { allow read: if true; }
    
    match /service_categories/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /service_categories/{docId=**} { allow read: if true; }
    
    match /brands/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /brands/{docId=**} { allow read: if true; }
    
    match /marketing_offers/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /marketing_offers/{docId=**} { allow read: if true; }
    
    match /marketing_campaigns/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /marketing_campaigns/{docId=**} { allow read: if true; }
    
    match /site_settings/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /site_settings/{docId=**} { allow read: if true; }
    
    match /service_areas/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /service_areas/{docId=**} { allow read: if true; }

    // Restricted Operational Data (Staff/Admin only)
    match /orders/{document=**} { allow read, write: if isStaff(); }
    match /bookings/{document=**} { allow read, write: if isStaff(); }
    match /leads/{document=**} { allow read, write: if isStaff(); }
    match /customers/{document=**} { allow read, write: if isStaff(); }
    match /employee_profiles/{document=**} { allow read: if isStaff(); allow write: if isAdmin(); }
    
    // Role Markers
    match /roles_admins/{uid} { allow read: if isSignedIn(); allow write: if isBootstrapAdmin(); }
    match /roles_employees/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // Global Admin catch-all: Bootstrap admin can do anything anywhere.
    match /{document=**} {
      allow read, write: if isBootstrapAdmin();
    }
  }
}
